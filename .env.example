# =============================================
# Time alvo
# TARGET_TEAM:        nome usado para casar com o HTML do site (accent/case insensitive)
# TARGET_TEAM_DISPLAY: nome amigável exibido na imagem gerada
# =============================================
TARGET_TEAM=ASSOCIAÇÃO SOROCABANA DE FUTSAL
TARGET_TEAM_DISPLAY=A.S.F. MAGNUS

# =============================================
# Origem dos dados
# Sub-7 Divisão A1 Temporada 2026 — categoria fixa
# =============================================
EVENT_URL=https://eventos.admfutsal.com.br/evento/908

# =============================================
# Comportamento
# =============================================
# Se true, em caso de falha do scrape e havendo cache de até 24h, usa o cache com aviso
ALLOW_STALE_CACHE=false
DEBUG=false

# =============================================
# Timeouts (ms)
# =============================================
HTTP_TIMEOUT_MS=15000
