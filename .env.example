# =============================================
# WhatsApp
# =============================================
# ID do grupo destino. Obtenha rodando: node enviar.js --list-groups
WHATSAPP_GROUP_ID=12036304XXXXXX@g.us

# =============================================
# Time alvo
# TARGET_TEAM:        nome usado para casar com o HTML do site (accent/case insensitive)
# TARGET_TEAM_DISPLAY: nome amigável exibido nas mensagens do WhatsApp
# =============================================
TARGET_TEAM=ASSOCIAÇÃO SOROCABANA DE FUTSAL
TARGET_TEAM_DISPLAY=A.S.F. MAGNUS

# =============================================
# Origem dos dados
# Sub-7 Divisão A1 Temporada 2026 — categoria fixa
# =============================================
EVENT_URL=https://eventos.admfutsal.com.br/evento/908

# =============================================
# Comportamento
# =============================================
# Se true, em caso de falha do scrape e havendo cache de até 24h, envia o cache com aviso
ALLOW_STALE_CACHE=false
DEBUG=false

# =============================================
# Timeouts (ms)
# =============================================
HTTP_TIMEOUT_MS=15000
WHATSAPP_TIMEOUT_MS=180000
