{
  "name": "magnus-bot",
  "version": "1.0.0",
  "description": "Bot para enviar classificação e artilharia do campeonato de futsal ADM (Sub-7 Divisão A1) para grupo de WhatsApp.",
  "main": "enviar.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node enviar.js",
    "dry": "node enviar.js --dry-run",
    "cache": "node enviar.js --dry-run --from-cache",
    "groups": "node enviar.js --list-groups",
    "listen": "node enviar.js --listen",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "cheerio": "1.0.0",
    "dotenv": "16.4.5",
    "qrcode-terminal": "0.12.0",
    "whatsapp-web.js": "1.26.0"
  }
}
